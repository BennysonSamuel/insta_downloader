{
  "name": "benload",
  "version": "1.0.0",
  "description": "Instagram video downloader — Hono backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --target node18 --out-dir dist --clean --no-splitting",
    "dev": "tsup src/index.ts --format cjs --target node18 --out-dir dist --clean --watch",
    "start": "node dist/index.js",
    "vercel-build": "tsup src/index.ts --format cjs --target node18 --out-dir dist --clean --no-splitting"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.20",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
